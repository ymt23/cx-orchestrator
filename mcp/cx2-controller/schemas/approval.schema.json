{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local/cx-orchestrator/approval.schema.json",
  "type": "object",
  "required": [
    "approval_id",
    "task_id",
    "kind",
    "status"
  ],
  "properties": {
    "approval_id": {
      "type": "string"
    },
    "task_id": {
      "type": "string"
    },
    "kind": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "pending",
        "allowed",
        "denied"
      ]
    },
    "summary": {
      "type": "string"
    },
    "raw": {
      "type": "object"
    }
  },
  "additionalProperties": true
}
