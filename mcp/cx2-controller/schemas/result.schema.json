{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local/cx-orchestrator/result.schema.json",
  "type": "object",
  "required": [
    "task_id",
    "status",
    "final_message",
    "log_paths"
  ],
  "properties": {
    "task_id": {
      "type": "string"
    },
    "status": {
      "type": "string"
    },
    "final_message": {
      "type": "string"
    },
    "changed_files": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "validation": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "risks": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "next_request": {
      "type": "string"
    },
    "runtime_settings": {
      "type": "object",
      "properties": {
        "model": {
          "type": [
            "string",
            "null"
          ]
        },
        "reasoning_effort": {
          "type": [
            "string",
            "null"
          ],
          "enum": [
            "low",
            "medium",
            "high",
            "xhigh",
            null
          ]
        },
        "speed_tier": {
          "type": "string",
          "enum": [
            "standard",
            "fast"
          ]
        },
        "service_tier": {
          "type": [
            "string",
            "null"
          ],
          "enum": [
            "fast",
            null
          ]
        }
      },
      "additionalProperties": true
    },
    "log_paths": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    }
  },
  "additionalProperties": true
}
